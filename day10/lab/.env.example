# Day 10 Lab — copy thành .env và điền nếu cần
#   cp .env.example .env

# === LLM Provider ===
# Thống nhất: gemini-3.1-flash-lite-preview
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
LLM_MODEL=gemma-4-31b-it

# === Embedding ===
# Thống nhất: SentenceTransformer ("Qwen/Qwen3-Embedding-0.6B")
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# === Vector DB ===
# Thống nhất: Qdrant
VECTOR_DB=qdrant
# QDRANT_URL=http://localhost:6333
QDRANT_API_KEY= 
QDRANT_CLUSTER_ENDPOINT=
# QDRANT_CONNECTION_MODE=memory # Bật nếu muốn chạy in-memory thay vì server

# === Monitoring & Observability (LangSmith) ===
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Freshness SLA (giờ) — dùng trong monitoring/freshness_check.py
FRESHNESS_SLA_HOURS=24
