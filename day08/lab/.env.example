# Day 08 Lab — RAG Pipeline (Updated TechStack)
# Copy file này thành .env và điền API key

# === LLM Provider ===
# Thống nhất: gemini-3.1-flash-lite-preview
LLM_PROVIDER=gemini
GOOGLE_API_KEY=your_google_api_key_here
LLM_MODEL=gemini-3.1-flash-lite-preview

# === Embedding ===
# Thống nhất: SentenceTransformer ("Qwen/Qwen3-Embedding-0.6B")
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# === Vector DB ===
# Thống nhất: Qdrant
VECTOR_DB=qdrant
# QDRANT_URL=http://localhost:6333
QDRANT_API_KEY= your_qdrant_api_key_here
QDRANT_CLUSTER_ENDPOINT = your_qdrant_cluster_endpoint_here
# QDRANT_CONNECTION_MODE=memory # Bật nếu muốn chạy in-memory thay vì server

# === Monitoring & Observability (LangSmith) ===
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=day08-rag-lab
